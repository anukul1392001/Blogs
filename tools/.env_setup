
sourced=0
if [ -n "${ZSH_EVAL_CONTEXT:-}" ]; then
  case "$ZSH_EVAL_CONTEXT" in
    *:file) sourced=1;;
  esac
elif [ -n "${BASH_SOURCE:-}" ]; then
  [ "${BASH_SOURCE[0]}" != "$0" ] && sourced=1
fi

if [ "$sourced" -eq 0 ]; then
  echo "ERROR: .env_setup must be sourced, not executed." >&2
  echo "Run: source .env_setup" >&2
  return 1 2>/dev/null || exit 1
fi

VENV_DIR="$HOME/nunam/zephyr430/.venv"
if [ -d "$VENV_DIR" ]; then
  export PATH="$VENV_DIR/bin:$PATH"
  source "$VENV_DIR/bin/activate"
fi

export PATH="$HOME/zephyr-sdk-0.17.4/arm-zephyr-eabi/bin:$PATH"
export ZEPHYR_SDK_INSTALL_DIR="$HOME/zephyr-sdk-0.17.4"

source "$HOME/nunam/zephyr430/zephyr/zephyr-env.sh"

alias lg1="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all"
alias lg2="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(auto)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'"
alias lg="lg1"

alias uncrustify-all='find . \( -name "*.cpp" -o -name "*.c" -o -name "*.h" \) -exec uncrustify -c $NUNAM_BATTERY_IOT_FIRMWARE_ROOT/.vscode/uncrustify.cfg --no-backup {} +'
